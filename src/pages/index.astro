---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.tsx';
import Timeline from '../components/Timeline.tsx';
import Intralogistics from '../components/Intralogistics.tsx';
import AIExpert from '../components/AIExpert.tsx';
import Offer from '../components/Offer.tsx';
import SocialProof from '../components/SocialProof.tsx';
import Contact from '../components/Contact.tsx';
import Footer from '../components/Footer.astro';
---

<Layout title="Artur Myzer — AI Expert & Intralogistics Consultant">
  <Header />
  <main>
    <Hero client:load />
    <div class="section-divider"></div>
    <Timeline client:visible />
    <div class="section-divider"></div>
    <Intralogistics client:visible />
    <div class="section-divider"></div>
    <AIExpert client:visible />
    <div class="section-divider"></div>
    <Offer client:visible />
    <div class="section-divider"></div>
    <SocialProof client:visible />
    <div class="section-divider"></div>
    <Contact client:visible />
  </main>
  <Footer />
</Layout>
