---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.tsx';
import HeroFuturistic from '../components/ui/hero-futuristic.tsx';
import FeatureProtocols from '../components/blocks/feature-protocols.tsx';
import PricingProtocols from '../components/blocks/pricing-protocols.tsx';
---

<Layout
  title="Artur Myzer | AI Management System dla firm B2B"
  description="AI w firmie bez chaosu. Zbuduj system, który naprawdę pracuje. Protokoły wdrożeniowe, Scorecard i JARVIS."
>
  <!-- HEADER z glow-menu -->
  <Header client:load />

  <main>
    <!-- 1) HERO — WebGPU 3D (client-only, bez SSR) -->
    <HeroFuturistic client:only="react" />

    <!-- 2) PROTOKOŁY — Feature108 z tabs -->
    <FeatureProtocols client:load />

    <!-- 3) PRICING -->
    <PricingProtocols client:load />
  </main>
</Layout>
