---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.tsx';
import About from '../components/About.tsx';
import Jarvis from '../components/Jarvis.tsx';
import Expertise from '../components/Expertise.tsx';
import Results from '../components/Results.tsx';
import Process from '../components/Process.tsx';
import Contact from '../components/Contact.tsx';
import Footer from '../components/Footer.astro';
---

<Layout title="Artur Myziak — AI Expert, JARVIS as a Service, Intralogistyka">
  <Header />
  <main>
    <Hero client:load />
    <div class="section-divider"></div>
    <About client:visible />
    <div class="section-divider"></div>
    <Jarvis client:visible />
    <div class="section-divider"></div>
    <Expertise client:visible />
    <div class="section-divider"></div>
    <Results client:visible />
    <div class="section-divider"></div>
    <Process client:visible />
    <div class="section-divider"></div>
    <Contact client:visible />
  </main>
  <Footer />
</Layout>
