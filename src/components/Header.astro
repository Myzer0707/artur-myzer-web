---
const navLinks = [
  { href: '#historia', label: 'Historia' },
  { href: '#intralogistyka', label: 'Intralogistyka' },
  { href: '#ai-expert', label: 'AI Expert' },
  { href: '#oferta', label: 'Oferta' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<!-- Scroll progress bar -->
<div class="scroll-progress" id="scroll-progress" style="transform: scaleX(0)"></div>

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="header">
  <div class="max-w-6xl mx-auto flex items-center justify-between h-20 px-6 lg:px-16">
    <a href="/" class="flex items-center gap-3 group relative z-10">
      <img src="/images/icon-white.svg" alt="Artur Myzer" class="w-10 h-10 group-hover:drop-shadow-[0_0_15px_rgba(74,219,200,0.4)] transition-all duration-300" />
      <div class="hidden sm:block">
        <span class="font-heading font-bold text-lg tracking-tight text-white transition-colors duration-300" id="logo-text">ARTUR MYZER</span>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link relative px-4 py-2 font-heading font-medium text-sm text-white/70 hover:text-white transition-all duration-300 rounded-lg hover:bg-white/10">
          {link.label}
        </a>
      ))}
      <a href="#kontakt" class="ml-4 relative inline-flex items-center gap-2 px-6 py-2.5 font-heading font-semibold text-sm rounded-xl
                                bg-gradient-to-r from-am-mint to-am-cyan text-am-dark
                                hover:shadow-[0_4px_20px_rgba(74,219,200,0.4)] hover:-translate-y-0.5
                                transition-all duration-300">
        Porozmawiajmy
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </nav>

    <button class="md:hidden relative z-10 p-2 rounded-lg hover:bg-white/10 transition-colors text-white" id="mobile-menu-btn" aria-label="Menu">
      <div class="w-6 h-5 flex flex-col justify-between" id="hamburger">
        <span class="block h-0.5 w-6 bg-current rounded-full transition-all duration-300 origin-center" id="line1"></span>
        <span class="block h-0.5 w-6 bg-current rounded-full transition-all duration-300" id="line2"></span>
        <span class="block h-0.5 w-4 bg-current rounded-full transition-all duration-300 origin-center ml-auto" id="line3"></span>
      </div>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden overflow-hidden transition-all duration-500 max-h-0" id="mobile-menu">
    <nav class="flex flex-col px-6 py-6 gap-1 bg-am-dark/95 backdrop-blur-xl border-t border-white/10">
      {navLinks.map((link, i) => (
        <a href={link.href}
           class="font-heading font-medium text-white/80 hover:text-am-mint py-3 px-4 rounded-lg hover:bg-white/5 transition-all duration-300"
           style={`animation-delay: ${i * 50}ms`}>
          {link.label}
        </a>
      ))}
      <a href="#kontakt" class="mt-4 py-3 px-6 bg-gradient-to-r from-am-mint to-am-cyan text-am-dark font-heading font-semibold text-sm rounded-xl text-center
                              hover:shadow-[0_4px_20px_rgba(74,219,200,0.4)] transition-all duration-300">
        Porozmawiajmy
      </a>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const line1 = document.getElementById('line1');
  const line2 = document.getElementById('line2');
  const line3 = document.getElementById('line3');
  let isOpen = false;

  btn?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      menu!.style.maxHeight = menu!.scrollHeight + 'px';
      line1!.style.transform = 'rotate(45deg) translateY(8px)';
      line2!.style.opacity = '0';
      line3!.style.transform = 'rotate(-45deg) translateY(-8px)';
      line3!.style.width = '1.5rem';
    } else {
      menu!.style.maxHeight = '0';
      line1!.style.transform = '';
      line2!.style.opacity = '';
      line3!.style.transform = '';
      line3!.style.width = '';
    }
  });

  menu?.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      isOpen = false;
      menu!.style.maxHeight = '0';
      line1!.style.transform = '';
      line2!.style.opacity = '';
      line3!.style.transform = '';
      line3!.style.width = '';
    })
  );

  // Header scroll behavior + progress bar
  const header = document.getElementById('header');
  const progress = document.getElementById('scroll-progress');

  function updateHeader() {
    const scrollY = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const scrollPercent = docHeight > 0 ? scrollY / docHeight : 0;

    if (progress) {
      progress.style.transform = `scaleX(${scrollPercent})`;
    }

    if (scrollY > 50) {
      header?.classList.add('bg-am-dark/90', 'backdrop-blur-xl', 'shadow-lg', 'shadow-black/10');
    } else {
      header?.classList.remove('bg-am-dark/90', 'backdrop-blur-xl', 'shadow-lg', 'shadow-black/10');
    }
  }

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();
</script>
