---
const navLinks = [
  { href: '#o-mnie', label: 'O mnie' },
  { href: '#jarvis', label: 'JARVIS' },
  { href: '#ekspertyza', label: 'Ekspertyza' },
  { href: '#proces', label: 'Proces' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<!-- Scroll progress bar -->
<div class="scroll-progress" id="scroll-progress" style="transform: scaleX(0)"></div>

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="header">
  <div class="max-w-6xl mx-auto flex items-center justify-between h-[72px] px-6 lg:px-12">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group relative z-10">
      <div class="relative">
        <div class="absolute inset-0 blur-lg rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"
             style="background: radial-gradient(circle, rgba(235,121,14,0.4), transparent 70%);"></div>
        <img src="/images/logo-white.svg" alt="Artur Myzer"
             class="relative h-8 w-auto transition-all duration-300"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'" />
        <span class="hidden items-center gap-2 font-heading font-bold text-lg text-white tracking-tight">
          ARTUR MYZER
        </span>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a href={link.href}
           class="relative px-4 py-2 font-heading font-medium text-sm text-white/60 hover:text-white transition-all duration-300 rounded-lg hover:bg-white/6">
          {link.label}
        </a>
      ))}
      <a href="#kontakt"
         class="ml-4 btn-primary text-sm py-2.5 px-6">
        Porozmawiajmy
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </nav>

    <!-- Mobile burger -->
    <button class="md:hidden relative z-10 p-2 rounded-lg hover:bg-white/8 transition-colors text-white"
            id="mobile-menu-btn" aria-label="Menu">
      <div class="w-6 h-5 flex flex-col justify-between" id="hamburger">
        <span class="block h-0.5 w-6 bg-current rounded-full transition-all duration-300 origin-center" id="line1"></span>
        <span class="block h-0.5 w-6 bg-current rounded-full transition-all duration-300" id="line2"></span>
        <span class="block h-0.5 w-4 bg-current rounded-full transition-all duration-300 origin-center ml-auto" id="line3"></span>
      </div>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden overflow-hidden transition-all duration-500 max-h-0" id="mobile-menu">
    <nav class="flex flex-col px-6 py-6 gap-1"
         style="background: rgba(13,13,13,0.98); backdrop-filter: blur(20px); border-top: 1px solid rgba(255,255,255,0.08);">
      {navLinks.map((link, i) => (
        <a href={link.href}
           class="font-heading font-medium text-white/70 hover:text-white py-3 px-4 rounded-lg hover:bg-white/5 transition-all duration-300">
          {link.label}
        </a>
      ))}
      <a href="#kontakt"
         class="mt-4 btn-primary text-sm py-3 px-6 justify-center">
        Porozmawiajmy
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const line1 = document.getElementById('line1');
  const line2 = document.getElementById('line2');
  const line3 = document.getElementById('line3');
  let isOpen = false;

  btn?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      menu!.style.maxHeight = menu!.scrollHeight + 'px';
      line1!.style.transform = 'rotate(45deg) translateY(8px)';
      line2!.style.opacity = '0';
      line3!.style.transform = 'rotate(-45deg) translateY(-8px)';
      line3!.style.width = '1.5rem';
    } else {
      menu!.style.maxHeight = '0';
      line1!.style.transform = '';
      line2!.style.opacity = '';
      line3!.style.transform = '';
      line3!.style.width = '';
    }
  });

  menu?.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      isOpen = false;
      menu!.style.maxHeight = '0';
      line1!.style.transform = '';
      line2!.style.opacity = '';
      line3!.style.transform = '';
      line3!.style.width = '';
    })
  );

  const header = document.getElementById('header');
  const progress = document.getElementById('scroll-progress');

  function updateHeader() {
    const scrollY = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const scrollPercent = docHeight > 0 ? scrollY / docHeight : 0;

    if (progress) progress.style.transform = `scaleX(${scrollPercent})`;

    if (scrollY > 40) {
      header?.classList.add('shadow-2xl', 'shadow-black/50');
      (header as HTMLElement).style.background = 'rgba(13,13,13,0.92)';
      (header as HTMLElement).style.backdropFilter = 'blur(24px)';
      (header as HTMLElement).style.webkitBackdropFilter = 'blur(24px)';
      (header as HTMLElement).style.borderBottom = '1px solid rgba(255,255,255,0.07)';
    } else {
      header?.classList.remove('shadow-2xl', 'shadow-black/50');
      (header as HTMLElement).style.background = 'transparent';
      (header as HTMLElement).style.backdropFilter = 'none';
      (header as HTMLElement).style.webkitBackdropFilter = 'none';
      (header as HTMLElement).style.borderBottom = '1px solid transparent';
    }
  }

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();
</script>
