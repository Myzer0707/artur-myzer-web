---
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '#historia', label: 'Historia' },
  { href: '#intralogistyka', label: 'Intralogistyka' },
  { href: '#ai-expert', label: 'AI Expert' },
  { href: '#oferta', label: 'Oferta' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<footer class="relative bg-am-dark overflow-hidden">
  <!-- Top gradient line -->
  <div class="h-px bg-gradient-to-r from-transparent via-am-mint/30 to-transparent"></div>

  <div class="container-narrow section-padding !py-16">
    <div class="grid md:grid-cols-3 gap-12 md:gap-8 mb-12">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-3 group mb-6">
          <img src="/images/icon-white.svg" alt="Artur Myzer" class="w-10 h-10 group-hover:drop-shadow-[0_0_15px_rgba(74,219,200,0.3)] transition-all" />
          <span class="font-heading font-bold text-white tracking-tight text-lg">ARTUR MYZER</span>
        </a>
        <p class="text-am-grey text-sm leading-relaxed max-w-xs">
          AI Expert & Intralogistics Consultant.
          Łączę sztuczną inteligencję z 18-letnim doświadczeniem operacyjnym.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">Nawigacja</h4>
        <nav class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <a href={link.href} class="text-am-grey hover:text-am-mint transition-colors text-sm">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">Kontakt</h4>
        <div class="flex flex-col gap-3">
          <a href="mailto:artur@arturmyzer.ai" class="text-am-grey hover:text-am-mint transition-colors text-sm">
            artur@arturmyzer.ai
          </a>
          <a href="https://www.linkedin.com/in/arturmyzer/" target="_blank" rel="noopener" class="text-am-grey hover:text-am-mint transition-colors text-sm">
            LinkedIn — Artur Myzer
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-am-grey/60 text-xs">&copy; {currentYear} Artur Myzer. Wszelkie prawa zastrzeżone. MYZER&reg; jest znakiem towarowym zastrzeżonym w UE.</p>
      <div class="flex items-center gap-4">
        <a href="https://www.linkedin.com/in/arturmyzer/" target="_blank" rel="noopener"
           class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-am-grey hover:text-am-mint hover:bg-white/10 transition-all">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
