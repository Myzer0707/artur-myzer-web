---
const currentYear = new Date().getFullYear();
---

<footer class="bg-myzer-dark border-t border-white/10">
  <div class="container-narrow section-padding !py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-myzer-orange rounded-lg flex items-center justify-center text-white font-heading font-bold text-sm">
          AM
        </div>
        <span class="font-heading font-semibold text-white">Artur Myzer</span>
      </div>

      <!-- Links -->
      <nav class="flex items-center gap-6 text-sm">
        <a href="#o-mnie" class="text-grey-cool hover:text-myzer-orange transition-colors">O mnie</a>
        <a href="#filary" class="text-grey-cool hover:text-myzer-orange transition-colors">Ekspertyza</a>
        <a href="#szkolenia" class="text-grey-cool hover:text-myzer-orange transition-colors">Szkolenia</a>
        <a href="#kontakt" class="text-grey-cool hover:text-myzer-orange transition-colors">Kontakt</a>
      </nav>

      <!-- Copyright -->
      <p class="text-grey-cool text-sm">
        &copy; {currentYear} Artur Myzer. Wszelkie prawa zastrzeżone.
      </p>
    </div>
  </div>
</footer>
