    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-am-primary rounded-lg flex items-center justify-center text-white font-heading font-bold text-sm">AM</div>
        <span class="font-heading font-semibold text-white tracking-tight">ARTUR MYZER</span>
      </div>
      <nav class="flex items-center gap-6 text-sm">
        <a href="#o-mnie" class="text-am-grey hover:text-am-mint transition-colors">O mnie</a>
        <a href="#filary" class="text-am-grey hover:text-am-mint transition-colors">Ekspertyza</a>
        <a href="#szkolenia" class="text-am-grey hover:text-am-mint transition-colors">Szkolenia</a>
