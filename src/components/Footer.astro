---
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '#o-mnie', label: 'O mnie' },
  { href: '#jarvis', label: 'JARVIS' },
  { href: '#ekspertyza', label: 'Ekspertyza' },
  { href: '#proces', label: 'Proces' },
  { href: '#kontakt', label: 'Kontakt' },
];

const companies = [
  { label: 'Myzer Intra', href: '#' },
  { label: 'VMT', href: '#' },
  { label: 'Alufance', href: '#' },
  { label: 'Mayhpi', href: '#' },
];
---

<footer class="relative overflow-hidden" style="background: #0d0d0d;">
  <!-- Top separator -->
  <div class="h-px" style="background: linear-gradient(90deg, transparent, rgba(235,121,14,0.25), transparent);"></div>

  <div class="max-w-6xl mx-auto px-6 lg:px-12 py-16">
    <div class="grid md:grid-cols-4 gap-12 md:gap-8 mb-12">

      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-3 group mb-5">
          <img
            src="/images/logo-white.svg"
            alt="Artur Myzer"
            class="h-8 w-auto transition-all duration-300"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='block'"
          />
          <span class="hidden font-heading font-bold text-white tracking-tight text-lg">ARTUR MYZER</span>
        </a>
        <p class="text-sm leading-relaxed max-w-xs mb-6" style="color: rgba(255,255,255,0.35);">
          AI Expert ktory zbudowal JARVIS — system AI zarzadzajacy firmami.
          Ekspert intralogistyki z 15+ lat doswiadczenia.
        </p>
        <!-- Social -->
        <div class="flex items-center gap-3">
          <a
            href="https://www.linkedin.com/in/arturmyzer/"
            target="_blank" rel="noopener"
            class="w-9 h-9 rounded-xl flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5"
            style="background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5);"
            onmouseover="this.style.background='rgba(235,121,14,0.12)'; this.style.color='#eb790e';"
            onmouseout="this.style.background='rgba(255,255,255,0.06)'; this.style.color='rgba(255,255,255,0.5)';"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
          <a
            href="mailto:artur.myziak@myzer.pl"
            class="w-9 h-9 rounded-xl flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5"
            style="background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5);"
            onmouseover="this.style.background='rgba(235,121,14,0.12)'; this.style.color='#eb790e';"
            onmouseout="this.style.background='rgba(255,255,255,0.06)'; this.style.color='rgba(255,255,255,0.5)';"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-heading font-semibold text-white text-xs uppercase tracking-widest mb-5">Nawigacja</h4>
        <nav class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm font-body transition-colors duration-200 hover:text-white"
              style="color: rgba(255,255,255,0.35);"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Companies -->
      <div>
        <h4 class="font-heading font-semibold text-white text-xs uppercase tracking-widest mb-5">Portfolio firm</h4>
        <div class="flex flex-col gap-3">
          {companies.map((c) => (
            <a
              href={c.href}
              class="text-sm font-body transition-colors duration-200 hover:text-white"
              style="color: rgba(255,255,255,0.35);"
            >
              {c.label}
            </a>
          ))}
          <a
            href="mailto:artur.myziak@myzer.pl"
            class="text-sm font-body transition-colors duration-200"
            style="color: rgba(235,121,14,0.7);"
            onmouseover="this.style.color='#eb790e';"
            onmouseout="this.style.color='rgba(235,121,14,0.7)';"
          >
            artur.myziak@myzer.pl
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4"
      style="border-top: 1px solid rgba(255,255,255,0.06);"
    >
      <p class="text-xs font-body" style="color: rgba(255,255,255,0.2);">
        &copy; {currentYear} Artur Myziak. Wszelkie prawa zastrzezone. MYZER&reg; jest znakiem towarowym zastrzezonym w UE.
      </p>
      <div class="flex items-center gap-2">
        <span class="text-xs font-body" style="color: rgba(255,255,255,0.15);">Zbudowane z</span>
        <span
          class="text-xs font-heading font-semibold px-2.5 py-1 rounded-full"
          style="background: rgba(235,121,14,0.08); color: rgba(235,121,14,0.6); border: 1px solid rgba(235,121,14,0.15);"
        >
          JARVIS
        </span>
      </div>
    </div>
  </div>
</footer>
