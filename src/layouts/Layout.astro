---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Artur Myzer | Super Moce Dla Twojej Firmy',
  description = 'Artur Myzer — System AI do zarzadzania firma. Kursy, automatyzacja, JARVIS.'
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Artur Myzer" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://arturmyzer.ai" />
    <meta property="og:locale" content="pl_PL" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Artur Myzer",
      "jobTitle": "AI Expert",
      "url": "https://arturmyzer.ai",
      "email": "artur@arturmyzer.ai",
      "sameAs": [
        "https://www.linkedin.com/in/arturmyzer/",
        "https://www.youtube.com/@arturmyzer",
        "https://x.com/arturmyzer"
      ],
      "knowsAbout": ["Artificial Intelligence", "JARVIS AI", "Automatyzacja", "Kursy AI"],
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
