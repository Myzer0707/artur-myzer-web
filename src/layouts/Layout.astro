---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Artur Myziak — AI Expert który zbudował JARVIS, system AI zarządzający firmami. Ekspert intralogistyki z 15+ lat doświadczenia. Poznaj JARVIS as a Service.'
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Artur Myziak" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://arturmyzer.ai" />
    <meta property="og:locale" content="pl_PL" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Artur Myziak",
      "alternateName": "Artur Myzer",
      "jobTitle": "AI Expert & Intralogistics Specialist",
      "url": "https://arturmyzer.ai",
      "email": "artur.myziak@myzer.pl",
      "sameAs": ["https://www.linkedin.com/in/arturmyzer/"],
      "knowsAbout": ["Artificial Intelligence", "JARVIS AI", "Intralogistics", "AGV", "AMR", "Lean Manufacturing"],
    })} />
  </head>
  <body class="bg-[#0d0d0d]">
    <slot />
  </body>
</html>
